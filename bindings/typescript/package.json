{
  "name": "kaleidoswap-sdk",
  "version": "0.4.0",
  "description": "TypeScript/JavaScript SDK for the Kaleidoswap protocol - trade RGB assets on Lightning Network",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/kaleidoswap/kaleido-sdk"
  },
  "keywords": [
    "bitcoin",
    "lightning",
    "rgb",
    "swap",
    "trading",
    "kaleidoswap"
  ],
  "author": "Kaleidoswap Team",
  "license": "MIT",
  "scripts": {
    "build": "npm run build:rust && npm run build:ts",
    "build:rust": "cargo build --release",
    "build:ts": "tsc",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.5.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.27",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "index.node",
    "native/"
  ]
}
