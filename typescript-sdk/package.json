{
    "name": "kaleido-sdk",
    "version": "0.1.3",
    "description": "Kaleidoswap SDK for TypeScript and JavaScript - trade RGB assets on Lightning Network",
    "keywords": [
        "bitcoin",
        "lightning",
        "rgb",
        "swap",
        "trading",
        "kaleidoswap",
        "wasm"
    ],
    "author": "Kaleidoswap Team",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/kaleidoswap/kaleido-sdk"
    },
    "type": "module",
    "packageManager": "pnpm@10.30.3",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.js",
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./rln": {
            "import": "./dist/rln.js",
            "require": "./dist/rln.js",
            "types": "./dist/rln.d.ts",
            "default": "./dist/rln.js"
        },
        "./generated/api-types": {
            "import": "./dist/generated/api-types.js",
            "require": "./dist/generated/api-types.js",
            "types": "./dist/generated/api-types.d.ts",
            "default": "./dist/generated/api-types.js"
        }
    },
    "files": [
        "dist/",
        "README.md"
    ],
    "scripts": {
        "generate:types": "bash ../scripts/generate_typescript_types.sh",
        "prebuild": "npm run generate:types",
        "build": "npm run build:ts",
        "build:ts": "tsc",
        "typecheck": "tsc --noEmit",
        "clean": "rm -rf dist pkg pkg-node src/generated",
        "test": "vitest run",
        "test:unit": "vitest run tests/unit tests/type-safety tests/client.test.ts",
        "test:integration": "vitest run tests/integration",
        "test:watch": "vitest",
        "lint": "eslint src --ext .ts",
        "lint:fix": "eslint src --ext .ts --fix",
        "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
        "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
        "prepublishOnly": "npm run build"
    },
    "devDependencies": {
        "@types/node": "^20.19.33",
        "@types/ws": "^8.18.1",
        "@typescript-eslint/eslint-plugin": "^8.42.0",
        "@typescript-eslint/parser": "^8.42.0",
        "eslint": "^8.57.1",
        "openapi-typescript": "^7.13.0",
        "prettier": "^3.8.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vitest": "^1.6.1"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "dependencies": {
        "openapi-fetch": "^0.15.2"
    },
    "pnpm": {
        "overrides": {
            "brace-expansion": "5.0.5",
            "flatted": "3.4.2",
            "minimatch": "10.2.4",
            "picomatch": "2.3.2",
            "esbuild": ">=0.25.0"
        }
    }
}
