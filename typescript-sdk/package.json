{
  "name": "kaleidoswap-sdk",
  "version": "0.4.0",
  "description": "Kaleidoswap SDK for TypeScript and JavaScript - trade RGB assets on Lightning Network",
  "keywords": [
    "bitcoin",
    "lightning",
    "rgb",
    "swap",
    "trading",
    "kaleidoswap",
    "wasm"
  ],
  "author": "Kaleidoswap Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kaleidoswap/kaleido-sdk"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "generate:types": "bash ../scripts/generate_typescript_types.sh",
    "prebuild": "npm run generate:types",
    "build": "npm run build:ts",
    "build:ts": "tsc",
    "clean": "rm -rf dist pkg pkg-node src/generated",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "openapi-typescript": "^7.10.1",
    "prettier": "^3.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@types/ws": "^8.18.1",
    "openapi-fetch": "^0.15.0",
    "ws": "^8.19.0"
  }
}