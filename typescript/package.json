{
  "name": "@kaleidoswap/kaleidoswap-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for KaleidoSwap - A decentralized exchange for Bitcoin and RGB assets",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest src/__tests__/client.integration.test.ts src/http/__tests__/client.integration.test.ts",
    "generate:types": "openapi-typescript /home/mo_/Code/kaleidoswap/kaleidoswap-maker/openapi.json -o src/types/schema.d.ts",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepare": "npm run build",
    "example:usdt-to-btc": "ts-node examples/usdt-to-btc-swap.ts",
    "example:test": "ts-node examples/test.ts",
    "example:buy-btc-onchain": "ts-node examples/onchain/buy-btc-onchain.ts",
    "example:sell-btc-onchain": "ts-node examples/onchain/sell-btc-onchain.ts",
    "example:atomic-swap-ln": "ts-node examples/atomic/atomic-swap-ln-to-ln.ts"
  },
  "keywords": [
    "kaleidoswap",
    "sdk",
    "typescript",
    "crypto",
    "trading"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "author": "moakilodash",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/mocha": "^10.0.10",
    "@types/node": "^18.15.11",
    "@typescript-eslint/eslint-plugin": "^5.57.1",
    "@typescript-eslint/parser": "^5.57.1",
    "eslint": "^8.37.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^4.2.1",
    "jest": "^29.7.0",
    "openapi-typescript": "^7.9.1",
    "prettier": "^2.8.7",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@types/ws": "^8.18.1",
    "ws": "^8.18.2"
  }
}
